# Server-only Stripe configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Launch-sale one-time Stripe Price (JPY 980). Do not put an actual Price ID in this file.
STRIPE_LAUNCH_PRICE_ID=
# Optional future regular one-time Stripe Price (JPY 1,980).
STRIPE_REGULAR_PRICE_ID=
# Selects the server-side Price without a hard-coded campaign end date: launch or regular.
STRIPE_SALE_PRICE_MODE=launch
# Public deployment origin used only by Vercel Functions for Checkout redirects.
PUBLIC_APP_URL=
# Server-only Firebase Admin configuration
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Server-only HMAC secret used to hash report access tokens (minimum 32 characters).
REPORT_ACCESS_TOKEN_SECRET=
# Required before enabling production Checkout.
LEGAL_SELLER_NAME=
LEGAL_RESPONSIBLE_PERSON=
LEGAL_ADDRESS=
LEGAL_PHONE=
LEGAL_CONTACT_EMAIL=
LEGAL_SUPPORT_HOURS=
# Public legal-document enactment date in YYYY-MM-DD format. Set this to the production launch date.
LEGAL_EFFECTIVE_DATE=
# Required by the production release checklist. Do not use draft names as production values.
SERVICE_NAME=
DIAGNOSIS_NAME=
PAID_PRODUCT_NAME=
# Comma-separated final display names, retained separately from stable internal IDs.
MAIN_TYPE_NAMES=
SUBTYPE_NAMES=
